      "locked": false,
      "text": "private static Integer[] twoSum(Integer[] nums, Integer target) {",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "private static Integer[] twoSum(Integer[] nums, Integer target) {",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6HFy7akPYq2-4UVEQmsqi",
      "type": "text",
      "x": -1287.6214499728987,
      "y": 791.3974944264277,
      "width": 374,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 99989240,
      "version": 60,
      "versionNonce": 871763192,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1775089462652,
      "link": null,
      "locked": false,
      "text": "Integer[] result = new Integer[2];",
      "fontSize": 20,
      "fontFamily": 8,

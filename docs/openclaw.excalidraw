    {
      "id": "YJzxRkbSGPh_vqaCg7UCy",
      "type": "text",
      "x": -1075.9483815170186,
      "y": 166.70798173573039,
      "width": 940.2562255859375,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 1303882632,
      "version": 513,
      "versionNonce": 1250232824,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1775093664732,
      "link": null,
      "locked": false,
      "text": "Logic:\n- Mỗi input chỉ có đúng một lời giải\n-> Sẽ không có trường hợp tìm không thấy kết quả hoặc tìm được nhiều hơn một kết quả\n- Không được dùng cùng một phần tử hai lần\n-> [2, 3] and target = 4, kết quả không được phép bằng 0, 0\n\nInput:\n- 2 <= nums.length <= 10⁴\n- 10⁹ <= nums[i] <= 10⁹\n- 10⁹ <= target <= 10⁹\n-> Ảnh hưởng tới kiểu dữ liệu sử dụng cho thuật toán\n\nOutput:\n- Trả về kết quả theo thứ tự bất kỳ -> By default, không cần làm gì thêm",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Logic:\n- Mỗi input chỉ có đúng một lời giải\n-> Sẽ không có trường hợp tìm không thấy kết quả hoặc tìm được nhiều hơn một kết quả\n- Không được dùng cùng một phần tử hai lần\n-> [2, 3] and target = 4, kết quả không được phép bằng 0, 0\n\nInput:\n- 2 <= nums.length <= 10⁴\n- 10⁹ <= nums[i] <= 10⁹\n- 10⁹ <= target <= 10⁹\n-> Ảnh hưởng tới kiểu dữ liệu sử dụng cho thuật toán\n\nOutput:\n- Trả về kết quả theo thứ tự bất kỳ -> By default, không cần làm gì thêm",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uGs3Ptw3pshkpk5yqTgC-",
      "type": "text",
      "x": -1458.1214499728987,
      "y": 756.3974944264277,
      "width": 715,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
